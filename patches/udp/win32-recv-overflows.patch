+    strncpy(statePtr->peerhost, packets->r_host,
+	    sizeof(statePtr->peerhost) - 1);
+    statePtr->peerhost[sizeof(statePtr->peerhost) - 1] = '\0';
     statePtr->peerport = packets->r_port;
     statePtr->packets = packets->next;
