#!/bin/sh
# Restart with tclsh. \
exec tclsh "$0" "$@"

# whalebuild -- build a "whale": a single-file Tcl/Tk 9 executable with a
# statically linked set of extensions and a zipfs image attached.
#
# The driver holds the mechanics (fetch, configure, make, appinit
# generation, link, image); per-extension knowledge lives in
# recipes/*.rcp. See README.md and NOTES.md.

package require Tcl 8.6-

set Root [file dirname [file dirname [file normalize [info script]]]]

# ---------------------------------------------------------------- util --

proc msg {s} {puts stderr "whalebuild: $s"; flush stderr}
proc die {s} {puts stderr "whalebuild: error: $s"; exit 1}

proc Run {log args} {
    # Run a command with output captured to $log; show the tail on failure.
    file mkdir [file dirname $log]
    if {[catch {exec {*}$args >& $log} err]} {
	catch {
	    set f [open $log]
	    set lines [split [string trimright [read $f] \n] \n]
	    close $f
	    puts stderr [join [lrange $lines end-24 end] \n]
	}
	die "command failed: [lindex $args 0] (log: $log)"
    }
}

proc RunIn {dir log args} {
    set here [pwd]
    cd $dir
    try { Run $log {*}$args } finally { cd $here }
}

proc RunTcl {log script} {
    # Feed a script to the native tclsh with REAL failure propagation.
    # tclsh evaluating stdin is a REPL even when stdin is a pipe: an
    # uncaught error is printed and evaluation CONTINUES, exiting 0 at
    # EOF — so a failed script passes silently (bit us for real:
    # `zipfs mkimg` hit ETXTBSY, the build still said "done" and left
    # yesterday's whale in place). Wrap so any error exits nonzero.
    set wrapped "if \[catch [list $script] err\] {puts stderr \$err; exit 1}"
    Run $log [NativeTclsh] << $wrapped\n
}

proc Glob1 {args} {
    # First match of a glob, or empty.
    lindex [lsort [glob -nocomplain {*}$args]] 0
}

proc ConfigVar {file var} {
    set f [open $file]
    set data [read $f]
    close $f
    if {[regexp -line "^${var}='(\[^'\]*)'" $data -> v]} {return $v}
    return {}
}

proc WithEnv {pairs script} {
    # Run $script with ::env overrides, restoring the old values after.
    set saved {}
    foreach {k v} $pairs {
	if {[info exists ::env($k)]} {
	    lappend saved $k [list 1 $::env($k)]
	} else {
	    lappend saved $k [list 0 {}]
	}
	set ::env($k) $v
    }
    try {
	uplevel 1 $script
    } finally {
	foreach {k st} $saved {
	    lassign $st had old
	    if {$had} {set ::env($k) $old} else {unset -nocomplain ::env($k)}
	}
    }
}

# ------------------------------------------------------------- recipes --

# A recipe evaluates in this namespace; each command fills ::CUR.
namespace eval rcpdsl {
    proc version   {v}         {dict set ::CUR version $v}
    proc source    {kind args} {dict set ::CUR source [linsert $args 0 $kind]}
    proc buildstyle {s}        {dict set ::CUR buildstyle $s}
    proc maketarget {t}        {dict set ::CUR maketarget $t}
    proc confargs  {args}      {
	# confargs {list} — every platform; confargs <platform> {list}
	if {[llength $args] == 1} {set args [linsert $args 0 *]}
	dict set ::CUR confargs {*}$args
    }
    proc requires  {list}      {dict set ::CUR requires $list}
    proc init      {prefix {safeproc {}}} {
	dict set ::CUR init $prefix
	dict set ::CUR safeinit $safeproc
    }
    proc libs      {platform flags} {dict set ::CUR libs $platform $flags}
    proc vfs       {globs}     {dict set ::CUR vfs $globs}
    proc vfsprune  {globs}     {dict set ::CUR vfsprune $globs}
    proc pkgindex  {text}      {dict set ::CUR pkgindex $text}
    proc platforms {list}      {dict set ::CUR platforms $list}
    proc native-tclsh {}       {dict set ::CUR nativetclsh 1}
    proc tool      {kind url}  {dict set ::CUR tool [list $kind $url]}
    proc ldextra   {flags}     {dict set ::CUR ldextra $flags}
    proc ingredient {name platform spec} {
	# A support library the extension builds against (referenced as
	# @CACHE@/<name>), cross-built ONCE into work/cache/<name> when
	# missing. Pinned by its source URL like tarball recipes — bump
	# the URL and delete work/cache/<name>* to move versions.
	dict set ::CUR ingredients $name [list $platform $spec]
    }
}

# An ingredient spec evaluates in this namespace, filling ::CURING.
namespace eval ingdsl {
    proc source {kind args} {dict set ::CURING source [linsert $args 0 $kind]}
    proc build  {script}    {dict set ::CURING build $script}
}

proc LoadRecipe {path} {
    set ::CUR [dict create \
	name [file rootname [file tail $path]] \
	version {} source {} buildstyle tea maketarget {} confargs {} \
	requires {} init {} safeinit {} libs {} vfs {} vfsprune {} pkgindex {} \
	platforms {linux win64} nativetclsh 0 tool {} ldextra {} \
	ingredients {}]
    set f [open $path]
    set body [read $f]
    close $f
    namespace eval rcpdsl $body
    return $::CUR
}

proc R {name key} {
    global Recipes
    dict get [dict get $Recipes $name] $key
}

proc ReqClosure {name} {
    # Transitive closure of a recipe's `requires`.
    set todo [list $name]
    set seen {}
    while {[llength $todo]} {
	set todo [lassign $todo n]
	foreach r [R $n requires] {
	    if {$r ni $seen} {lappend seen $r; lappend todo $r}
	}
    }
    return $seen
}

proc SortByRequires {pkgs} {
    # Dependencies before dependents (requires outside the set ignored).
    set order {}
    set left $pkgs
    while {[llength $left]} {
	set next {}
	set stuck 1
	foreach n $left {
	    set ready 1
	    foreach r [R $n requires] {
		if {$r in $left} {set ready 0; break}
	    }
	    if {$ready} {lappend order $n; set stuck 0} else {lappend next $n}
	}
	if {$stuck} {die "circular requires among: $left"}
	set left $next
    }
    return $order
}

# --------------------------------------------------------------- fetch --

proc FetchTarball {url dst log} {
    file mkdir [file dirname $dst]
    set tgz $dst.tar.gz
    Run $log curl -sSL -o $tgz $url
    set x $dst.extract
    file delete -force $x
    file mkdir $x
    Run $log tar xzf $tgz -C $x
    set tops [glob -directory $x *]
    if {[llength $tops] == 1 && [file isdirectory [lindex $tops 0]]} {
	file rename [lindex $tops 0] $dst
	file delete -force $x
    } else {
	file rename $x $dst
    }
}

proc FetchCache {name} {
    # Pristine source tree in the shared cache: fetched once; -update
    # pulls git sources (tarballs are pinned by URL — bump the recipe
    # and clean the cache to move).
    global Root Update
    set dst [file join $Root work cache $name]
    set src [R $name source]
    set log [file join $Root work cache logs fetch-$name.log]
    if {[file exists $dst]} {
	if {$Update && [lindex $src 0] eq "git"
		&& ![info exists ::Pulled($dst)]} {
	    set ::Pulled($dst) 1
	    msg "update $name (git pull)"
	    RunIn $dst $log git pull --ff-only
	    RunIn $dst $log git submodule update --init --recursive
	}
	return $dst
    }
    switch -- [lindex $src 0] {
	tarball {
	    msg "fetch $name ([lindex $src 1])"
	    FetchTarball [lindex $src 1] $dst $log
	}
	git {
	    msg "fetch $name (git clone)"
	    file mkdir [file dirname $dst]
	    Run $log git clone --depth 1 --recurse-submodules \
		--shallow-submodules [lindex $src 1] $dst
	}
	default {die "recipe $name: unknown source kind '[lindex $src 0]'"}
    }
    return $dst
}

proc Fetch {name} {
    # Per-platform source tree, copied from the cache. Everything builds
    # in-tree (out-of-tree builds of third-party extensions used to break
    # in subtle ways), so each platform owns a full copy it may dirty.
    # With -update the existing copy is refreshed by a careful rsync:
    # --checksum leaves content-equal files untouched (no spurious
    # rebuilds), no --delete keeps build artifacts, and only genuinely
    # changed sources get a fresh mtime for make to notice.
    global P Update
    switch -- [lindex [R $name source] 0] {
	tclpkgs {return [Fetch tcl]}
	from    {return [Fetch [lindex [R $name source] 1]]}
    }
    set dst [SrcDir $name]
    if {[file exists $dst]} {
	if {$Update && ![info exists ::Synced($dst)]} {
	    set ::Synced($dst) 1
	    set cache [FetchCache $name]
	    msg "sync $name into [dict get $P name] tree (rsync)"
	    Run [file join [dict get $P logs] sync-$name.log] \
		rsync -a --checksum $cache/ $dst/
	}
	return $dst
    }
    set cache [FetchCache $name]
    file mkdir [file dirname $dst]
    msg "copy $name into [dict get $P name] tree"
    file copy $cache $dst
    return $dst
}

proc SrcDir {name} {
    global P Recipes
    set src [R $name source]
    switch -- [lindex $src 0] {
	tclpkgs {return [file join [SrcDir tcl] pkgs [lindex $src 1]]}
	from    {return [SrcDir [lindex $src 1]]}
    }
    return [file join [dict get $P work] src $name]
}

proc FetchTool {name} {
    # A build-host tool a recipe needs (e.g. critcl); pristine cache copy.
    global Root
    lassign [R $name tool] kind url
    set dst [file join $Root work cache tool-$name]
    if {[file exists $dst]} {return $dst}
    set log [file join $Root work cache logs tool-$name.log]
    switch -- $kind {
	git {
	    msg "fetch $name build tool (git clone)"
	    file mkdir [file dirname $dst]
	    Run $log git clone --depth 1 $url $dst
	}
	default {die "recipe $name: unknown tool kind '$kind'"}
    }
    return $dst
}

proc BuildIngredients {name} {
    # Build the recipe's missing ingredients: support libraries the
    # extension compiles against (@CACHE@/<ing>), cross-built once into
    # work/cache/<ing>. Source lands in work/cache/<ing>.src; the build
    # script runs in it under `sh -e` with @OUT@ -> the install prefix
    # and @JOBS@ -> the -jobs value. The prefix is written as
    # <ing>.tmp and renamed on success, so a failed build never leaves
    # a half-populated ingredient that would pass the exists check.
    global P Root
    dict for {ing pspec} [R $name ingredients] {
	lassign $pspec plat spec
	if {$plat ni [list * [dict get $P name]]} continue
	set dst [file join $Root work cache $ing]
	if {[file exists $dst]} continue
	set ::CURING [dict create source {} build {}]
	namespace eval ingdsl $spec
	set src    [dict get $::CURING source]
	set script [dict get $::CURING build]
	if {$src eq {} || $script eq {}} {
	    die "$name: ingredient $ing needs both `source` and `build`"
	}
	set sdir [file join $Root work cache $ing.src]
	set log  [file join $Root work cache logs ing-$ing.log]
	if {![file exists $sdir]} {
	    switch -- [lindex $src 0] {
		tarball {
		    msg "fetch ingredient $ing ([lindex $src 1])"
		    FetchTarball [lindex $src 1] $sdir $log
		}
		git {
		    msg "fetch ingredient $ing (git clone)"
		    file mkdir [file dirname $sdir]
		    Run $log git clone --depth 1 --recurse-submodules \
			--shallow-submodules [lindex $src 1] $sdir
		}
		default {die "$name: ingredient $ing: unknown source\
		    kind '[lindex $src 0]'"}
	    }
	}
	set tmp $dst.tmp
	file delete -force $tmp
	msg "build ingredient $ing (once, into work/cache/$ing)"
	RunIn $sdir $log sh -e -c [string map \
	    [list @OUT@ $tmp @JOBS@ [dict get $P jobs]] $script]
	file rename $tmp $dst
    }
}

# --------------------------------------------------------------- build --

proc CoreBuild {name} {
    # Build Tcl or Tk in-tree (<src>/unix or <src>/win) and install it.
    global P
    set bdir [file join [SrcDir $name] [dict get $P subdir]]
    set log  [file join [dict get $P logs] $name.log]
    set conf [list ./configure --disable-shared --prefix=[dict get $P inst]]
    if {[dict get $P host] ne ""} {
	lappend conf --host=[dict get $P host]
    }
    if {$name eq "tk"} {
	lappend conf --with-tcl=[file join [dict get $P inst] lib]
    }
    if {![file exists [file join $bdir Makefile]]} {
	msg "configure $name"
	RunIn $bdir $log {*}$conf
    }
    msg "make $name"
    RunIn $bdir $log make -j[dict get $P jobs]
    RunIn $bdir $log make install
}

proc ExtBuild {name} {
    # TEA extension: in-tree configure --disable-shared && make (the tree
    # is a per-platform copy, so dirtying it is fine).
    global P Root
    set bdir [SrcDir $name]
    set log  [file join [dict get $P logs] $name.log]
    set conf [list ./configure --disable-shared \
	--with-tcl=[file join [dict get $P inst] lib]]
    if {"tk" in [R $name requires]} {
	lappend conf --with-tk=[file join [dict get $P inst] lib]
    }
    if {[dict get $P host] ne ""} {
	lappend conf --host=[dict get $P host]
    }
    # @CACHE@ -> work/cache (shared ingredients, e.g. a cross-built
    # support library like static OpenSSL for win64). Declared
    # ingredients were built by BuildIngredients before this point, so
    # a missing one here means an undeclared reference — fail with the
    # name instead of letting configure die on a cryptic header check.
    dict for {plat flags} [R $name confargs] {
	if {$plat in [list * [dict get $P name]]} {
	    foreach f $flags {
		if {[regexp {@CACHE@/([^/ =]+)} $f -> ing]
			&& ![file exists [file join $Root work cache $ing]]} {
		    die "$name needs the work/cache/$ing ingredient —\
			declare it with `ingredient` in recipes/$name.rcp\
			or build it by hand"
		}
	    }
	    lappend conf {*}[string map \
		[list @CACHE@ [file join $Root work cache]] $flags]
	}
    }
    if {[R $name nativetclsh]} {
	set ::env(TCLSH_NATIVE) [NativeTclsh]
    }
    if {![file exists [file join $bdir Makefile]]} {
	msg "configure $name"
	RunIn $bdir $log {*}$conf
    }
    msg "make $name"
    set target [R $name maketarget]
    RunIn $bdir $log make -j[dict get $P jobs] {*}$target
    unset -nocomplain ::env(TCLSH_NATIVE)
}

proc CritclBuild {name} {
    # A critcl collection (tcllibc-style): run the source tree's sak.tcl
    # to compile via critcl, then assemble a static archive from critcl's
    # object cache. critcl builds module bodies PIC-only; companions come
    # in both flavors — prefer non-PIC, fall back to PIC (legal in an
    # executable). See NOTES.md for the full story.
    global P Root
    set bdir [file join [dict get $P builds] $name]
    set aout [file join $bdir lib$name.a]
    set log  [file join [dict get $P logs] $name.log]
    set src  [SrcDir $name]
    set home [file join $Root work tools home]
    file mkdir $bdir $home

    # The critcl application, installed once as a build-host tool.
    set toolpfx   [file join $Root work tools critcl]
    set critclapp [file join $toolpfx bin critcl]
    if {![file exists $critclapp]} {
	set csrc [FetchTool $name]
	msg "install critcl (build tool)"
	WithEnv [list HOME $home] {
	    RunIn $csrc $log [NativeTclsh] build.tcl install --prefix $toolpfx
	}
    }

    msg "critcl $name (sak)"
    WithEnv [list HOME $home \
	    PATH [file join $toolpfx bin][expr {[info exists ::env(PATH)] ?
		":$::env(PATH)" : ""}] \
	    TCLLIBPATH [file join $src modules]] {
	RunIn $src $log [NativeTclsh] sak.tcl critcl -keep -libdir $bdir
    }

    set cache [file join $src .critcl]
    set objs {}
    foreach pic [lsort [glob -nocomplain -directory $cache *_pic.o]] {
	set plain [string range $pic 0 end-7].o
	lappend objs [expr {[file exists $plain] ? $plain : $pic}]
    }
    foreach o [lsort [glob -nocomplain -directory $cache *.o]] {
	if {[string match *_pic.o $o] || $o in $objs} continue
	lappend objs $o
    }
    if {![llength $objs]} {die "$name: no objects in critcl cache $cache"}
    file delete -force $aout
    Run $log ar cr $aout {*}$objs
    Run $log ranlib $aout
}

proc ExtLib {name} {
    global P
    if {[R $name buildstyle] eq "critcl"} {
	return [file join [dict get $P builds] $name lib$name.a]
    }
    # TEA packages with a stubs API (itcl, tdbc) ship two archives —
    # skip the stub one: it has no <Pkg>_Init and strands the linker.
    foreach a [lsort [glob -nocomplain -directory [SrcDir $name] *.a]] {
	if {![string match *stub* [file tail $a]]} {return $a}
    }
    die "no static library found for $name"
}

proc ProbeTcl9 {sh} {
    # Does $sh run Tcl 9 with zipfs? (thread's cross-configure and
    # `zipfs mkimg` both need exactly that.)
    set probe {puts [expr {[package vsatisfies [package provide Tcl] 9.0-]
	&& [llength [info commands zipfs]] > 0}]}
    if {[catch {exec $sh << $probe\n} out]} {return 0}
    return [expr {[string trim $out] eq "1"}]
}

proc NativeTclsh {} {
    # A zipfs-capable native Tcl 9 tclsh: -native / env override first
    # (any Tcl 9 kit qualifies), then the linux build's own install,
    # then the PATH.
    global Root Native
    if {[info exists ::NativeFound]} {return $::NativeFound}
    set cands {}
    if {$Native ne ""} {lappend cands $Native}
    lappend cands [Glob1 [file join $Root work linux install bin tclsh9*]]
    lappend cands {*}[auto_execok tclsh9.0]
    foreach sh $cands {
	if {$sh eq ""} continue
	if {[ProbeTcl9 $sh]} {return [set ::NativeFound $sh]}
	msg "note: $sh is not a zipfs-capable Tcl 9 tclsh, skipping"
    }
    die "no native Tcl 9 tclsh found; build linux first or pass\
	-native <tclsh9-or-kit> (needed for zipfs mkimg and cross-configure)"
}

# ---------------------------------------------------------- link/image --

proc GenAppinit {exts} {
    global P Root
    set externs {}
    set regs {}
    foreach name $exts {
	set prefix [R $name init]
	if {$prefix eq ""} continue
	lappend externs "extern Tcl_LibraryInitProc ${prefix}_Init;"
	set safe [R $name safeinit]
	if {$safe ne ""} {
	    lappend externs "extern Tcl_LibraryInitProc $safe;"
	    lappend regs "    Tcl_StaticLibrary(NULL, \"$prefix\",\
		${prefix}_Init, $safe);"
	} else {
	    lappend regs "    Tcl_StaticLibrary(NULL, \"$prefix\",\
		${prefix}_Init, NULL);"
	}
    }
    set f [open [file join $Root templates [dict get $P appinit]]]
    set text [read $f]
    close $f
    set text [string map [list @EXTERNS@ [join $externs \n] \
	@REGISTRATIONS@ [join $regs \n]] $text]
    set out [file join [dict get $P builds] appinit.c]
    file mkdir [dict get $P builds]
    set f [open $out w]
    puts $f $text
    close $f
    return $out
}

proc Link {exts out} {
    global P Root
    set inst [dict get $P inst]
    set lib  [file join $inst lib]
    set cc   [dict get $P cc]
    set log  [file join [dict get $P logs] link.log]
    set withtk [expr {"tk" in $exts}]

    # On Windows a whale with Tk is a GUI-subsystem binary (wish
    # model: interactive REPL = Tk's built-in console); without Tk
    # it is a console one. WHALE_GUI selects the entry point and the
    # console wiring in the win template.
    set cflags [dict get $P cflags]
    set ldflags [dict get $P ldflags]
    if {[dict get $P name] eq "win64"} {
	if {$withtk} {
	    lappend cflags -DWHALE_GUI
	    lappend ldflags -mwindows
	} else {
	    lappend ldflags -mconsole
	}
    }

    set c [GenAppinit $exts]
    set o [file join [dict get $P builds] appinit.o]
    msg "compile appinit"
    Run $log $cc {*}$cflags -I[file join $inst include] \
	-c -o $o $c

    set objs [list $o]
    set ldextra {}
    foreach name $exts {
	if {[R $name buildstyle] in {tea critcl}} {
	    lappend objs [ExtLib $name]
	}
	lappend ldextra {*}[R $name ldextra]
    }
    set stubs [list [Glob1 -directory $lib libtclstub*.a]]
    set cores {}
    if {$withtk} {
	set stubs [linsert $stubs 0 [Glob1 -directory $lib libtkstub*.a]]
	lappend cores [Glob1 -directory $lib libtcl9tk*.a]
	set syslibs [ConfigVar [file join $lib tkConfig.sh] TK_LIBS]
    } else {
	set syslibs [ConfigVar [file join $lib tclConfig.sh] TCL_LIBS]
    }
    lappend cores [Glob1 -directory $lib libtcl9.0.a]
    if {[lindex $cores end] eq ""} {
	lset cores end [Glob1 -directory $lib libtcl90.a]
    }
    foreach name $exts {
	dict for {plat flags} [R $name libs] {
	    if {$plat ne [dict get $P name]} continue
	    # @SRC@ -> the recipe's source tree (e.g. an in-tree
	    # prebuilt library shipped with the extension);
	    # @CACHE@ -> work/cache (shared cross-built ingredients).
	    lappend syslibs {*}[string map \
		[list @SRC@ [SrcDir $name] \
		     @CACHE@ [file join $Root work cache]] $flags]
	}
    }
    msg "link [file tail $out]"
    Run $log $cc {*}$ldflags {*}$ldextra -o $out {*}$objs \
	{*}$stubs {*}$cores {*}$syslibs
}

proc PruneTree {dir patterns} {
    # Drop files/dirs whose tail matches a `vfsprune` pattern: wrapping
    # whole directories (vfs {modules/*}) keeps package layouts intact
    # but drags tests/docs/build leftovers along — this trims them.
    foreach path [glob -nocomplain -directory $dir *] {
	set pruned 0
	foreach p $patterns {
	    if {[string match $p [file tail $path]]} {
		file delete -force $path
		set pruned 1
		break
	    }
	}
	if {!$pruned && [file isdirectory $path]} {
	    PruneTree $path $patterns
	}
    }
}

proc Image {exts bare out appdir} {
    global P Root
    set vfs [file join [dict get $P work] vfs]
    set log [file join [dict get $P logs] image.log]
    file delete -force $vfs
    file mkdir [file join $vfs lib]

    # Skeleton: the core build's script-library zip. The Tk zip carries
    # both tcl_library and tk_library.
    if {"tk" in $exts} {
	set zip [Glob1 [file join [SrcDir tk] [dict get $P subdir] libtk9*.zip]]
    } else {
	set zip [Glob1 [file join [SrcDir tcl] [dict get $P subdir] libtcl9*.zip]]
    }
    if {$zip eq ""} {die "core script-library zip not found"}
    Run $log unzip -q -d $vfs $zip

    foreach name $exts {
	set pi [string trim [R $name pkgindex]]
	set patterns [R $name vfs]
	if {$pi eq "" && ![llength $patterns]} continue
	set dir [file join $vfs lib $name]
	file mkdir $dir
	if {$pi ne ""} {
	    set f [open [file join $dir pkgIndex.tcl] w]
	    puts $f "# static pkgIndex generated by whalebuild"
	    puts $f $pi
	    close $f
	}
	foreach pattern $patterns {
	    foreach path [glob -nocomplain \
		    -directory [SrcDir $name] {*}$pattern] {
		file copy -force $path $dir
	    }
	}
	if {[llength [R $name vfsprune]]} {
	    PruneTree $dir [R $name vfsprune]
	}
    }

    # Third-party notices for binary redistribution (BSD notice
    # clauses; Apache-2.0 NOTICE once OpenSSL is linked statically):
    # every battery's license file(s) ride in the image under
    # lib/<name>/, an ingredient's under lib/<consumer>/<ingredient>-*.
    foreach name [concat tcl $exts] {
	set dir [file join $vfs lib $name]
	foreach f [glob -nocomplain -directory [SrcDir $name] \
		license.terms LICENSE LICENSE.* COPYING COPYING.* UNLICENSE] {
	    file mkdir $dir
	    file copy -force $f [file join $dir [file tail $f]]
	}
	dict for {ing pspec} [R $name ingredients] {
	    if {[lindex $pspec 0] ni [list * [dict get $P name]]} continue
	    foreach f [glob -nocomplain -directory \
		    [file join $Root work cache $ing.src] \
		    license.terms LICENSE LICENSE.* COPYING COPYING.*] {
		file mkdir $dir
		file copy -force $f [file join $dir $ing-[file tail $f]]
	    }
	}
    }

    if {$appdir ne ""} {
	# Embedded application: contents (incl. main.tcl) at image root.
	foreach path [glob -nocomplain -directory $appdir *] {
	    file copy -force $path $vfs
	}
    }

    msg "zipfs mkimg [file tail $out]"
    RunTcl $log [list zipfs mkimg $out $vfs $vfs {} $bare]
    file attributes $out -permissions 0o755
}

# ---------------------------------------------------------------- wrap --

proc WrapCmd {argv} {
    # sdx-wrap analog on core zipfs: pack an app dir (main.tcl at its
    # root, optional lib/) into a zip kit runnable as `whale app.kit`.
    # -exec prepends a shebang and marks the kit executable (zip
    # readers ignore prefix data), so `./app.kit` works on unix with a
    # whale in PATH. For a standalone single-file app use
    # `whalebuild build -app dir -out file` instead.
    global Root Native
    set Native {}
    if {[info exists ::env(WHALEBUILD_NATIVE_TCLSH)]} {
	set Native $::env(WHALEBUILD_NATIVE_TCLSH)
    }
    set exec 0
    set paths {}
    for {set i 0} {$i < [llength $argv]} {incr i} {
	set opt [lindex $argv $i]
	switch -- $opt {
	    -exec   {set exec 1}
	    -native {
		if {[incr i] >= [llength $argv]} {die "-native needs a value"}
		set Native [file normalize [lindex $argv $i]]
	    }
	    default {lappend paths $opt}
	}
    }
    if {[llength $paths] != 2} {die "usage: whalebuild wrap ?-exec? appdir out.kit"}
    lassign $paths indir out
    set indir [file normalize $indir]
    set out [file normalize $out]
    if {![file exists [file join $indir main.tcl]]} {
	die "wrap: $indir must contain main.tcl"
    }
    set log [file join $Root work cache logs wrap.log]
    msg "wrap [file tail $indir] -> [file tail $out]"
    if {$exec} {
	set hdr $out.hdr
	set f [open $hdr w]
	puts $f "#!/usr/bin/env whale"
	close $f
	set script [list zipfs mkimg $out $indir $indir {} $hdr]
    } else {
	set script [list zipfs mkzip $out $indir $indir]
    }
    RunTcl $log $script
    if {$exec} {
	file delete $out.hdr
	file attributes $out -permissions 0o755
    }
    msg "done: $out"
}

# ---------------------------------------------------------------- pack --

proc PackCmd {argv} {
    # sdx `wrap -runtime` analog (a starpack), no toolchain involved:
    # take an EXISTING whale, merge its image with an app dir, attach
    # the merged image to the whale's bare prefix. The core does the
    # heavy lifting: `zipfs mkimg ... infile` copies only passOffset
    # bytes of infile — i.e. it strips an already-attached image
    # itself. Works with any zipfs-capable Tcl 9 as the packer, and
    # any whale (or other zipfs kit) as the runtime.
    global Root Native
    set Native {}
    if {[info exists ::env(WHALEBUILD_NATIVE_TCLSH)]} {
	set Native $::env(WHALEBUILD_NATIVE_TCLSH)
    }
    set runtime {}
    set paths {}
    for {set i 0} {$i < [llength $argv]} {incr i} {
	set opt [lindex $argv $i]
	switch -- $opt {
	    -runtime {
		if {[incr i] >= [llength $argv]} {die "-runtime needs a value"}
		set runtime [file normalize [lindex $argv $i]]
	    }
	    -native {
		if {[incr i] >= [llength $argv]} {die "-native needs a value"}
		set Native [file normalize [lindex $argv $i]]
	    }
	    default {lappend paths $opt}
	}
    }
    if {[llength $paths] != 2} {
	die "usage: whalebuild pack ?-runtime whale? appdir out"
    }
    lassign $paths indir out
    set indir [file normalize $indir]
    set out [file normalize $out]
    if {$runtime eq ""} {
	set runtime [file join $Root work linux whale]
    }
    if {![file exists $runtime]} {die "pack: no runtime at $runtime"}
    if {$out eq $runtime} {die "pack: output would clobber the runtime"}
    if {![file exists [file join $indir main.tcl]]} {
	die "pack: $indir must contain main.tcl"
    }

    set vfs [file join $Root work pack-vfs]
    set log [file join $Root work cache logs pack.log]
    msg "pack [file tail $indir] onto [file tail $runtime] ->\
	[file tail $out]"
    set script {}
    append script "proc merge {src dst} {\n"
    append script "    foreach f \[glob -nocomplain -directory \$src *\] {\n"
    append script "        set t \[file join \$dst \[file tail \$f\]\]\n"
    append script "        if {\[file isdirectory \$f\]} {\n"
    append script "            file mkdir \$t\n"
    append script "            merge \$f \$t\n"
    append script "        } else {\n"
    append script "            file copy -force \$f \$t\n"
    append script "        }\n"
    append script "    }\n"
    append script "}\n"
    append script [list zipfs mount $runtime //zipfs:/whalepack]\n
    append script [list file delete -force $vfs]\n
    append script [list file mkdir $vfs]\n
    append script [list merge //zipfs:/whalepack $vfs]\n
    append script [list merge $indir $vfs]\n
    append script [list zipfs unmount //zipfs:/whalepack]\n
    append script [list zipfs mkimg $out $vfs $vfs {} $runtime]\n
    RunTcl $log $script
    file delete -force $vfs
    file attributes $out -permissions 0o755
    msg "done: $out"
}

# ---------------------------------------------------------------- main --

proc Profile {platform} {
    global Root
    set work [file join $Root work $platform]
    set base [dict create name $platform work $work \
	inst [file join $work install] builds [file join $work build] \
	logs [file join $work logs] jobs 4]
    switch -- $platform {
	linux {
	    return [dict merge $base [dict create \
		subdir unix host {} cc gcc exe {} appinit appinit.c.in \
		cflags {-O2} ldflags {}]]
	}
	win64 {
	    # The subsystem flag (-mconsole/-mwindows) is decided at
	    # link time: GUI subsystem when tk is in the set.
	    return [dict merge $base [dict create \
		subdir win host x86_64-w64-mingw32 \
		cc x86_64-w64-mingw32-gcc exe .exe \
		appinit appinit-win.c.in \
		cflags {-O2 -DUNICODE -D_UNICODE -DSTATIC_BUILD} \
		ldflags {-municode -static-libgcc}]]
	}
	default {die "unknown platform '$platform' (linux, win64)"}
    }
}

proc BuildCmd {argv} {
    global Root Recipes P Native Update
    set platform linux
    set flavor {}
    set pkgs {}
    set appdir {}
    set out {}
    set jobs 4
    set Update 0
    set Native {}
    if {[info exists ::env(WHALEBUILD_NATIVE_TCLSH)]} {
	set Native $::env(WHALEBUILD_NATIVE_TCLSH)
    }
    for {set i 0} {$i < [llength $argv]} {incr i} {
	set opt [lindex $argv $i]
	switch -- $opt {
	    -update   {set Update 1; continue}
	    -platform -
	    -pkgs -
	    -flavor -
	    -app -
	    -out -
	    -jobs -
	    -native   {}
	    default   {die "unknown option '$opt'"}
	}
	if {[incr i] >= [llength $argv]} {die "option $opt needs a value"}
	set val [lindex $argv $i]
	switch -- $opt {
	    -platform {set platform $val}
	    -pkgs     {set pkgs $val}
	    -flavor   {set flavor $val}
	    -app      {set appdir [file normalize $val]}
	    -out      {set out [file normalize $val]}
	    -jobs     {set jobs $val}
	    -native   {set Native [file normalize $val]}
	}
    }
    if {$flavor ne "" && [llength $pkgs]} {
	die "-flavor and -pkgs are mutually exclusive"
    }
    if {$flavor eq ""} {set flavor all}
    set P [Profile $platform]
    dict set P jobs $jobs

    set Recipes [dict create]
    foreach path [glob -directory [file join $Root recipes] *.rcp] {
	set r [LoadRecipe $path]
	dict set Recipes [dict get $r name] $r
    }
    foreach name [concat tcl $pkgs] {
	if {![dict exists $Recipes $name]} {die "no recipe for '$name'"}
    }

    # Resolve the package set: an explicit -pkgs list (completed with
    # its `requires` closure), or a named flavor over all recipes.
    if {[llength $pkgs]} {
	foreach name $pkgs {
	    foreach r [ReqClosure $name] {
		if {$r ni $pkgs} {
		    msg "adding $r (required by $name)"
		    lappend pkgs $r
		}
	    }
	}
    } else {
	set known {}
	foreach name [lsort [dict keys $Recipes]] {
	    if {$name ne "tcl"} {lappend known $name}
	}
	switch -- $flavor {
	    all {set pkgs $known}
	    cli {
		# Everything that neither is nor needs the GUI core.
		foreach name $known {
		    if {$name eq "tk" || "tk" in [ReqClosure $name]} {
			msg "flavor cli: excluding $name (GUI)"
			continue
		    }
		    lappend pkgs $name
		}
	    }
	    default {die "unknown flavor '$flavor' (all, cli)"}
	}
    }

    # Filter extensions not supported on this platform, then order
    # dependencies before dependents.
    set use {}
    foreach name $pkgs {
	if {$platform ni [R $name platforms]} {
	    msg "skipping $name (not supported on $platform)"
	    continue
	}
	lappend use $name
    }
    set use [SortByRequires $use]

    if {$appdir ne "" && ![file exists [file join $appdir main.tcl]]} {
	die "-app dir must contain main.tcl"
    }
    set suffix [expr {$flavor eq "all" ? "" : "-$flavor"}]
    if {$out eq ""} {
	set out [file join [dict get $P work] whale$suffix[dict get $P exe]]
    }

    file mkdir [dict get $P logs]
    Fetch tcl
    CoreBuild tcl
    if {"tk" in $use} {
	Fetch tk
	CoreBuild tk
    }
    foreach name $use {
	BuildIngredients $name
	switch -- [R $name buildstyle] {
	    tea    {Fetch $name; ExtBuild $name}
	    critcl {Fetch $name; CritclBuild $name}
	    none   {Fetch $name}
	}
    }
    set bare [file join [dict get $P builds] whale-bare$suffix[dict get $P exe]]
    Link $use $bare
    Image $use $bare $out $appdir
    msg "done: $out"
}

switch -- [lindex $argv 0] {
    build {BuildCmd [lrange $argv 1 end]}
    wrap  {WrapCmd [lrange $argv 1 end]}
    pack  {PackCmd [lrange $argv 1 end]}
    default {
	puts stderr "usage: whalebuild build ?-platform linux|win64?\
	    ?-flavor all|cli? ?-pkgs {tk sqlite3 ...}? ?-app dir? ?-out file?\
	    ?-jobs N? ?-native tclsh9? ?-update?\n\
	    \ \ \ whalebuild wrap ?-exec? ?-native tclsh9? appdir out.kit\n\
	    \ \ \ whalebuild pack ?-runtime whale? ?-native tclsh9? appdir out"
	exit 2
    }
}
