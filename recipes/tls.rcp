# TclTLS 2.0.1 (core.tcl-lang.org). The tls C code is static; OpenSSL
# linkage differs by platform ON PURPOSE:
#  - linux: DYNAMIC from the system — libssl.so.3 ABI is stable and
#    admins apply security updates without rebuilding the whale;
#  - win64: STATIC from the work/cache/openssl-win64 ingredient
#    (declared below, cross-built automatically when missing) —
#    Windows has no system OpenSSL, and a whale is single-file by
#    design (no DLLs next to the exe). Security updates there mean
#    rebuilding the kit; that is the platform's normal cost.
# OpenSSL >= 3.2 is required on win64: tcltls then defaults the CA
# store to org.openssl.winstore:// (the native ROOT store), so
# verification works out of the box with no -cafile/-castore wiring.
# `make` breaks in the doc generator (dtplite wants tcllib) — build the
# binaries target only. tls.tcl must ship next to the static pkgindex.
version 2.0.1
source tarball https://core.tcl-lang.org/tcltls/tarball/tls-2.0.1/tcltls.tar.gz
platforms {linux win64}
maketarget binaries
ingredient openssl-win64 win64 {
    source tarball https://github.com/openssl/openssl/releases/download/openssl-3.5.7/openssl-3.5.7.tar.gz
    build {
	./Configure mingw64 no-shared no-apps no-docs no-tests \
	    --prefix=@OUT@ --libdir=lib \
	    --cross-compile-prefix=x86_64-w64-mingw32-
	make -j@JOBS@
	make install_sw
    }
}
# --disable-hardening: -fstack-protector would need libssp on mingw,
# and -lssp drags in libssp-0.dll — breaking the single-file whale
# (none of the other batteries are hardened either).
confargs win64 {--with-openssl-dir=@CACHE@/openssl-win64 --enable-static-ssl
    --disable-hardening}
libs linux {-lssl -lcrypto}
libs win64 {-L@CACHE@/openssl-win64/lib -lssl -lcrypto
    -lws2_32 -lgdi32 -lcrypt32 -lbcrypt}
vfs {library/tls.tcl}
pkgindex {
    package ifneeded tls 2.0.1 [list ::apply {{dir} {
	load {} Tls
	source -encoding utf-8 [file join $dir tls.tcl]
    }} $dir]
}
init Tls
