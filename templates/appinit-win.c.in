/*
 * appinit for a whalebuild kit (win64), after win/tclAppInit.c resp.
 * win/winMain.c: UNICODE entry, slashes in argv[0], no CRT globbing.
 * Generated: the driver fills @EXTERNS@ and @REGISTRATIONS@ from the
 * recipe list, and defines WHALE_GUI when Tk is in the set.
 *
 * WHALE_GUI builds are GUI-subsystem (wish model): entered via
 * wWinMain, driven by Tk_Main. Interactively (no startup script) Tk
 * comes up eagerly and the REPL is Tk's built-in console
 * (generic/tkConsole.c + tk_library/console.tcl — already in the
 * image); Tk_InitConsoleChannels only hijacks std channels that are
 * actually invalid, so redirected runs keep writing to their files.
 * With a startup script Tk stays lazy as everywhere else.
 *
 * Registry and Dde are always registered: in a static build their
 * objects are folded into libtcl90.a by the stock makefile.
 */

#include "tcl.h"
#ifdef WHALE_GUI
#include "tk.h"
#endif

#define WIN32_LEAN_AND_MEAN
#define STRICT
#include <windows.h>
#undef STRICT
#undef WIN32_LEAN_AND_MEAN
#include <locale.h>
#include <stdlib.h>
#include <tchar.h>
#if defined(__GNUC__)
int _CRT_glob = 0;
#endif

extern Tcl_LibraryInitProc Registry_Init;
extern Tcl_LibraryInitProc Dde_Init;
extern Tcl_LibraryInitProc Dde_SafeInit;

@EXTERNS@

/*
 * Starkit-style kits on core zipfs: when the startup script is really
 * a zip archive with main.tcl at its root, mount it on //zipfs:/kit
 * and run that instead ("whale app.kit"). The core's own argv[1]
 * handling for this sits behind SUPPORT_BUILTIN_ZIP_INSTALL, which is
 * an #error stub in 9.0.4 — so the whale does it itself.
 */
static const char whaleKitBootScript[] =
    "namespace eval ::whale {}\n"
    "proc ::whale::KitBoot {path} {\n"
    "    if {[string match //zipfs:/* $path]} {return {}}\n"
    "    if {![file isfile $path]} {return {}}\n"
    "    if {[catch {zipfs mount $path //zipfs:/kit}]} {return {}}\n"
    "    if {![file exists //zipfs:/kit/main.tcl]} {\n"
    "        catch {zipfs unmount //zipfs:/kit}\n"
    "        return {}\n"
    "    }\n"
    "    if {[file isdirectory //zipfs:/kit/lib]} {\n"
    "        lappend ::auto_path //zipfs:/kit/lib\n"
    "    }\n"
    "    return //zipfs:/kit/main.tcl\n"
    "}\n";

static void
Whale_KitBoot(
    Tcl_Interp *interp)
{
    Tcl_Obj *scriptObj = Tcl_GetStartupScript(NULL);
    Tcl_Obj *cmd;
    int code;

    if (scriptObj == NULL) {
	return;
    }
    if (Tcl_EvalEx(interp, whaleKitBootScript, -1, TCL_EVAL_GLOBAL)
	    != TCL_OK) {
	return;
    }
    cmd = Tcl_NewListObj(0, NULL);
    Tcl_ListObjAppendElement(NULL, cmd,
	    Tcl_NewStringObj("::whale::KitBoot", -1));
    Tcl_ListObjAppendElement(NULL, cmd, scriptObj);
    Tcl_IncrRefCount(cmd);
    code = Tcl_EvalObjEx(interp, cmd, TCL_EVAL_GLOBAL);
    Tcl_DecrRefCount(cmd);
    if (code == TCL_OK) {
	Tcl_Obj *mainObj = Tcl_GetObjResult(interp);
	Tcl_Size len;

	(void)Tcl_GetStringFromObj(mainObj, &len);
	if (len > 0) {
	    Tcl_SetStartupScript(mainObj, NULL);
	}
    }
    Tcl_ResetResult(interp);
}

static int
Whale_AppInit(
    Tcl_Interp *interp)
{
    if (Tcl_Init(interp) == TCL_ERROR) {
	return TCL_ERROR;
    }

    Tcl_StaticLibrary(NULL, "Registry", Registry_Init, NULL);
    Tcl_StaticLibrary(NULL, "Dde", Dde_Init, Dde_SafeInit);

@REGISTRATIONS@

    /* See the unix template: make lib/<pkg>/ visible to auto_path. */
    Tcl_EvalEx(interp,
	    "if {[file isdirectory //zipfs:/app/lib]} {"
	    " lappend auto_path //zipfs:/app/lib }",
	    -1, TCL_EVAL_GLOBAL);

    Whale_KitBoot(interp);

#ifdef WHALE_GUI
    /*
     * Interactive (no startup script, e.g. a double-click): a GUI
     * subsystem binary has no usable std channels, so bring Tk up
     * now and attach the built-in console as the REPL. Script runs
     * skip this and keep Tk lazy.
     */
    if (Tcl_GetStartupScript(NULL) == NULL) {
	Tcl_SetVar2(interp, "tk_library", NULL,
		"//zipfs:/app/tk_library", TCL_GLOBAL_ONLY);
	if (Tk_Init(interp) == TCL_ERROR) {
	    return TCL_ERROR;
	}
	if (Tk_CreateConsoleWindow(interp) == TCL_ERROR) {
	    return TCL_ERROR;
	}
    }
#endif

    return TCL_OK;
}

#ifdef WHALE_GUI

int APIENTRY
_tWinMain(
    HINSTANCE hInstance,
    HINSTANCE hPrevInstance,
    LPTSTR lpszCmdLine,
    int nCmdShow)
{
    TCHAR **argv;
    int argc;
    TCHAR *p;
    (void)hInstance;
    (void)hPrevInstance;
    (void)lpszCmdLine;
    (void)nCmdShow;

    setlocale(LC_ALL, "C");

    argc = __argc;
    argv = __targv;

    for (p = argv[0]; *p != '\0'; p++) {
	if (*p == '\\') {
	    *p = '/';
	}
    }

    TclZipfs_AppHook(&argc, &argv);
    Tk_Main(argc, argv, Whale_AppInit);
    return 0;
}

#else /* !WHALE_GUI */

int
_tmain(
    int argc,
    TCHAR *argv[])
{
    TCHAR *p;

    setlocale(LC_ALL, "C");

    for (p = argv[0]; *p != '\0'; p++) {
	if (*p == '\\') {
	    *p = '/';
	}
    }

    TclZipfs_AppHook(&argc, &argv);
    Tcl_Main(argc, argv, Whale_AppInit);
    return 0;
}

#endif /* WHALE_GUI */
